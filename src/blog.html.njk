---
layout: layouts/base.njk
permalink: blog.html
assetPrefix: ""
navCurrent: blog
pageTitleEl: AccessCity — Νέα & Ενημερώσεις
pageTitleEn: AccessCity — News & Updates
pageDescriptionEl: Νέα, ανακοινώσεις και ενημερώσεις από την ομάδα του AccessCity.
pageDescriptionEn: News, announcements, and updates from the AccessCity team.
canonicalUrl: https://accesscity.gr/blog
---
<main id="main" class="wrap" tabindex="-1">
  <section class="blog-hero" aria-labelledby="blog-hero-title">
    <p class="eyebrow" data-el="{{ site.blog.eyebrowEl }}" data-en="{{ site.blog.eyebrowEn }}">
      {{ site.blog.eyebrowEl }}
    </p>
    <h1 id="blog-hero-title" data-el="{{ site.blog.titleEl }}" data-en="{{ site.blog.titleEn }}">
      {{ site.blog.titleEl }}
    </h1>
    <p class="lead" data-el="{{ site.blog.leadEl }}" data-en="{{ site.blog.leadEn }}">
      {{ site.blog.leadEl }}
    </p>
  </section>

  <section aria-label="Αναρτήσεις / Posts">
    <div class="blog-grid">
      {% for post in publishedPosts %}
      <article class="blog-card">
        <div class="blog-card__media{% if post.cardTheme == 'alt' %} blog-card__media--alt{% endif %}" aria-hidden="true"></div>
        <div class="blog-card__body">
          <div class="blog-card__meta">
            <span class="blog-tag{% if post.tagStyle == 'announcement' %} blog-tag--announcement{% endif %}" data-el="{{ post.categoryEl }}" data-en="{{ post.categoryEn }}">
              {{ post.categoryEl }}
            </span>
            <time datetime="{{ post.publishDate }}" class="blog-date" data-el="{{ post.dateLabelEl }}" data-en="{{ post.dateLabelEn }}">
              {{ post.dateLabelEl }}
            </time>
          </div>
          <h2 class="blog-card__title" data-el="{{ post.titleEl }}" data-en="{{ post.titleEn }}">
            <a href="blog/{{ post.slug }}.html" class="blog-card__title-link" data-el="{{ post.titleEl }}" data-en="{{ post.titleEn }}">
              {{ post.titleEl }}
            </a>
          </h2>
          <p class="blog-card__excerpt" data-el="{{ post.excerptEl }}" data-en="{{ post.excerptEn }}">
            {{ post.excerptEl }}
          </p>
          <a href="blog/{{ post.slug }}.html" class="blog-card__link" data-el="{{ site.ui.readMoreEl }}" data-en="{{ site.ui.readMoreEn }}">
            {{ site.ui.readMoreEl }}
          </a>
        </div>
      </article>
      {% endfor %}
    </div>
  </section>
</main>